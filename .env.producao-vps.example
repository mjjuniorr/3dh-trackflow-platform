APP_HOST=track.3dhmanaus.com.br
PUBLIC_BASE_URL=https://track.3dhmanaus.com.br
CORS_ORIGIN=https://track.3dhmanaus.com.br
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencryptresolver

POSTGRES_DB=tracking
POSTGRES_USER=tracking
POSTGRES_PASSWORD=troque_esta_senha_producao
JWT_SECRET=troque_este_segredo_producao
JWT_EXPIRES_IN=8h
AUTH_MODE=hybrid
OIDC_ISSUER=https://auth.3dhmanaus.com.br/realms/3dh
OIDC_CLIENT_ID=trackflow-web
OIDC_AUDIENCE=trackflow-web
OIDC_JWKS_URL=
OIDC_DEFAULT_COMPANY_ID=
PORTAL_URL=https://portal.3dhmanaus.com.br

SEED_ADMIN_EMAIL=admin@3dhmanaus.com.br
SEED_ADMIN_PASSWORD=troque_esta_senha_admin
MOBILE_REGISTRATION_SECRET=troque_este_token_mobile

FRONTEND_IMAGE=ghcr.io/mjjuniorr/3dh-trackflow-web:producao
BACKEND_IMAGE=ghcr.io/mjjuniorr/3dh-trackflow-backend:producao

KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=rastreamento
KAFKA_CLIENT_ID=trackflow-backend
KAFKA_GROUP_ID=trackflow-consumer-group-prod
KAFKA_ENABLED=true
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
