APP_HOST=track.3dhmanaus.shop
PUBLIC_BASE_URL=https://track.3dhmanaus.shop
CORS_ORIGIN=https://track.3dhmanaus.shop
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_ENTRYPOINTS=websecure

POSTGRES_DB=tracking
POSTGRES_USER=tracking
POSTGRES_PASSWORD=troque_esta_senha_homologacao
JWT_SECRET=troque_este_segredo_homologacao
JWT_EXPIRES_IN=8h

SEED_ADMIN_EMAIL=admin@3dhmanaus.shop
SEED_ADMIN_PASSWORD=troque_esta_senha_admin

FRONTEND_IMAGE=ghcr.io/mjjuniorr/3dh-trackflow-web:homologacao
BACKEND_IMAGE=ghcr.io/mjjuniorr/3dh-trackflow-backend:homologacao

KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=rastreamento
KAFKA_CLIENT_ID=trackflow-backend
KAFKA_GROUP_ID=trackflow-consumer-group-hml
KAFKA_ENABLED=true
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
